# ─── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
*.egg-info/

# Virtual environment — recreated locally (python3.11 + pinned reqs), never tracked
.venv/
venv/
env/

# ─── Quarto / Typst ──────────────────────────────────────
.quarto/
*_files/
*_cache/
/_site/
/_book/

# Rendered PDFs — produced by `quarto render`; finals are rendered at
# publish time, not version-controlled. DELETE this line if you decide
# to commit student-facing PDFs.
*.pdf

# ─── Build / release artifacts ───────────────────────────
# Stamped template repos + stripped releases are generated by the build
# scripts and re-stamped at publish; never source.
/build/
/release/
*_release/

# ─── macOS ───────────────────────────────────────────────
.DS_Store
._*
.AppleDouble
.LSOverride

# ─── Editors ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~

# ─── Misc ────────────────────────────────────────────────
*.log
.env
.env.*
